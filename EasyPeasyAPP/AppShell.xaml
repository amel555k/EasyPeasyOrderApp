<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="EasyPeasyAPP.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:EasyPeasyAPP"
    xmlns:pages="clr-namespace:EasyPeasyAPP.Pages"
    Shell.FlyoutBehavior="Disabled"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#1A1A1A"
    Title="EasyPeasyAPP">

    <!-- Main Page -->
    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

    <!-- Order Page -->
    <ShellContent
        Title="Order"
        ContentTemplate="{DataTemplate pages:OrderPage}"
        Route="OrderPage" />


    <!-- About Page -->
    <ShellContent
        Title="O Nama"
        ContentTemplate="{DataTemplate pages:AboutPage}"
        Route="AboutPage" />

   
    <!-- Profile Page -->
    <ShellContent
        Title="Profil"
        ContentTemplate="{DataTemplate pages:ProfilePage}"
        Route="ProfilePage" />
    <ShellContent
    Title="Narudžbe"
    ContentTemplate="{DataTemplate pages:NarudzbeHistoryPage}"
    Route="NarudzbeHistoryPage" />
</Shell>