<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EasyPeasyAPP.Pages.ProfilePage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="Transparent">

    <Grid>
        <Image Source="background.png" Aspect="AspectFill"/>

        <ScrollView>
            <VerticalStackLayout Padding="40"
                                 Spacing="20"
                                 VerticalOptions="Center">

                <Image Source="logo.png"
                       WidthRequest="120"
                       HeightRequest="120"
                       Margin="0,0,0,20"/>

                <Label Text="PROFILE"
                       Style="{StaticResource Header1Style}"
                       HorizontalOptions="Center"
                       Margin="0,0,0,30"/>

                <!-- Full Name -->
                <Border Style="{StaticResource CardBorderStyle}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <Entry x:Name="DisplayNameEntry"
                           Placeholder="Full Name"
                           Style="{StaticResource InputStyle}"/>
                </Border>

                <!-- Email -->
                <Border Style="{StaticResource CardBorderStyle}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <Entry x:Name="EmailEntry"
                           Placeholder="Email"
                           Keyboard="Email"
                           Style="{StaticResource InputStyle}"/>
                </Border>

                <!-- Phone -->
                <Border Style="{StaticResource CardBorderStyle}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <Entry x:Name="TelefonEntry"
                           Placeholder="Phone Number"
                           Keyboard="Telephone"
                           Style="{StaticResource InputStyle}"/>
                </Border>

                <!-- Address -->
                <Border Style="{StaticResource CardBorderStyle}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <Entry x:Name="AdresaEntry"
                           Placeholder="Address"
                           Style="{StaticResource InputStyle}"/>
                </Border>

                <Button Text="SAVE CHANGES"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Clicked="OnSaveClicked"
                        Margin="0,10,0,0"/>

                <Label x:Name="ErrorLabel"
                       TextColor="Red"
                       FontFamily="LeagueSpartan"
                       FontSize="14"
                       HorizontalOptions="Center"
                       IsVisible="False"
                       Margin="0,10,0,0"/>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
