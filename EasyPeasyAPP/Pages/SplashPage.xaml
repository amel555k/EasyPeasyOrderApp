<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EasyPeasyAPP.Pages.SplashPage">
    
    <Grid>
        <Image Source="background.png"
               Aspect="AspectFill"
               HorizontalOptions="Fill"
               VerticalOptions="Fill"/>
        
        <VerticalStackLayout x:Name="SplashGroup"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            Spacing="20">
            
            <Image Source="logo.png"
                   WidthRequest="280"
                   HeightRequest="280"
                   HorizontalOptions="Center"
                   Aspect="AspectFit"/>
            
            <Border BackgroundColor="{StaticResource AccentGold}"
                    HorizontalOptions="Center"
                    Padding="40,15">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                
                <Label Text="ORDER APP"
                       FontFamily="BebasNeue"
                       FontSize="64"
                       TextColor="White"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Border>
            
        </VerticalStackLayout>
    </Grid>
    
</ContentPage>