<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EasyPeasyAPP.Pages.Auth.RegisterPage"
             NavigationPage.HasNavigationBar="False">

	<Grid>
		<Image Source="background.png" Aspect="AspectFill"/>

		<ScrollView>
			<VerticalStackLayout Padding="40"
                                Spacing="20"
                                VerticalOptions="Center">

				<Image Source="logo.png"
                       WidthRequest="120"
                       HeightRequest="120"
                       Margin="0,0,0,20"/>

				<Label Text="REGISTER"
                       Style="{StaticResource Header1Style}"
                       HorizontalOptions="Center"
                       Margin="0,0,0,30"/>

				<Border Style="{StaticResource CardBorderStyle}">
					<Border.StrokeShape>
						<RoundRectangle CornerRadius="10"/>
					</Border.StrokeShape>
					<Entry x:Name="DisplayNameEntry"
                           Placeholder="Full Name"
                           Style="{StaticResource InputStyle}"/>
				</Border>

				<Border Style="{StaticResource CardBorderStyle}">
					<Border.StrokeShape>
						<RoundRectangle CornerRadius="10"/>
					</Border.StrokeShape>
					<Entry x:Name="EmailEntry"
                           Placeholder="Email"
                           Keyboard="Email"
                           Style="{StaticResource InputStyle}"/>
				</Border>

				<Border Style="{StaticResource CardBorderStyle}">
					<Border.StrokeShape>
						<RoundRectangle CornerRadius="10"/>
					</Border.StrokeShape>
					<Entry x:Name="PasswordEntry"
                           Placeholder="Password"
                           IsPassword="True"
                           Style="{StaticResource InputStyle}"/>
				</Border>

				<Border Style="{StaticResource CardBorderStyle}">
					<Border.StrokeShape>
						<RoundRectangle CornerRadius="10"/>
					</Border.StrokeShape>
					<Entry x:Name="ConfirmPasswordEntry"
                           Placeholder="Confirm Password"
                           IsPassword="True"
                           Style="{StaticResource InputStyle}"/>
				</Border>

				<Button Text="REGISTER"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Clicked="OnRegisterClicked"
                        Margin="0,10,0,0"/>

				<HorizontalStackLayout HorizontalOptions="Center"
                                      Spacing="5"
                                      Margin="0,20,0,0">
					<Label Text="Already have an account?"
                           TextColor="{StaticResource Gray}"
                           FontFamily="LeagueSpartan"
                           FontSize="16"/>
					<Label Text="Login"
                           TextColor="{StaticResource AccentGold}"
                           FontFamily="LeagueSpartan"
                           FontSize="16"
                           FontAttributes="Bold">
						<Label.GestureRecognizers>
							<TapGestureRecognizer Tapped="OnLoginTapped"/>
						</Label.GestureRecognizers>
					</Label>
				</HorizontalStackLayout>

				<Label x:Name="ErrorLabel"
                       TextColor="Red"
                       FontFamily="LeagueSpartan"
                       FontSize="14"
                       HorizontalOptions="Center"
                       IsVisible="False"
                       Margin="0,10,0,0"/>

			</VerticalStackLayout>
		</ScrollView>
	</Grid>

</ContentPage>